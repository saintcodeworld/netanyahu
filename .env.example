# OPENAI_API_KEY: Required for OpenAI API calls.
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# UPSTASH REDIS: Required for multiplayer bomb sync and persistence.
# Create a free Redis database at https://console.upstash.com
# Then add these as environment variables in Vercel project settings.
UPSTASH_REDIS_REST_URL="YOUR_UPSTASH_REDIS_REST_URL"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"

# SUPABASE: Required for server-side prize pool tracking.
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
